rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function validImageUpload() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /business-images/{imagePath=**} {
      allow read: if true;
      allow write: if signedIn() && validImageUpload();
    }

    match /property-images/{imagePath=**} {
      allow read: if true;
      allow write: if signedIn() && validImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
