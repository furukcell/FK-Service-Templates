rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /business-images/{imagePath=**} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /property-images/{imagePath=**} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
