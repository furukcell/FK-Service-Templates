# Form gelince işletmeye e-posta bildirimi göndermek için kullanılır.
# Resend kullanılmazsa boş bırakılabilir; form kaydı yine çalışır, sadece mail bildirimi atlanır.
RESEND_API_KEY=
REQUEST_NOTIFICATION_TO=
REQUEST_NOTIFICATION_FROM=FK Service Templates <onboarding@resend.dev>

# Demo için false veya boş bırakılabilir.
# Müşteri tesliminde admin paneli login zorunlu yapmak için true yapılır.
NEXT_PUBLIC_REQUIRE_ADMIN_AUTH=false
